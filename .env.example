# InjectiveLens Agent Guard live read-only source configuration.
# Copy the variables you need into your shell environment before starting the demo.
#
# Day 4 never asks for private keys, seed phrases, or signing permissions.
# If live endpoints are missing or fail, the app marks source coverage partial
# and treats missing data as unknown rather than safe.

# Optional. Cosmos LCD endpoint for read-only account balances.
# The adapter calls:
#   GET {INJECTIVE_LCD_REST_URL}/cosmos/bank/v1beta1/balances/{address}
INJECTIVE_LCD_REST_URL=https://testnet.sentry.lcd.injective.network:443

# Optional. Provider-specific read-only endpoint templates.
# Use {market}, {network}, and {subaccount_id} placeholders as needed.
INJECTIVE_MARKET_SNAPSHOT_URL=
INJECTIVE_POSITIONS_URL=
INJECTIVE_READ_TIMEOUT_SECONDS=3

# Optional demo account shown in the UI. Use a funded Injective testnet account
# for live read-only checks; do not paste private keys or seed phrases.
INJECTIVE_DEMO_ACCOUNT=

# Day 5 proof boundary.
# external_tx never signs or broadcasts from the app. After you manually
# broadcast an Injective testnet assessment memo/event, paste its tx hash here
# so /api/proof/record and /api/proof/verify can show recorded/verified state.
INJECTIVE_PROOF_RECORDER_MODE=external_tx
INJECTIVE_PROOF_TX_HASH=
INJECTIVE_PROOF_BLOCK_HEIGHT=
INJECTIVE_PROOF_EXPLORER_URL=

# Day 7 local state. Keeps latest assessment/proof history across API restarts.
INJECTIVELENS_STATE_FILE=data/injectivelens_state.json

# Azure Container Apps deployment defaults.
# These are used by Dockerfile, scripts/azure_start.sh, and scripts/azure_deploy_containerapp.sh.
HOST=0.0.0.0
PORT=8000
INJECTIVELENS_STATIC_DIR=/app/frontend-dist
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=rg-injectivelens-agent-guard
AZURE_APP_NAME=injectivelens-agent-guard
# Must be globally unique if set. Example: injectivelensguard123
AZURE_ACR_NAME=

# Legacy MantleLens migration-base settings below. They are retained only
# because this workspace was copied from the Mantle version and may still be
# useful while porting reusable proof/state code.

# Mantle mainnet JSON-RPC. Public RPC works for read-only calls; paid RPC is better for reliability.
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# Optional. Full Moralis RPC Node URL from the dashboard, for example:
# https://site1.moralis-nodes.com/mantle/<api-key>
MORALIS_NODE_URL=

# Optional. Used for token/address security evidence.
GOPLUS_API_KEY=
GOPLUS_BASE_URL=https://api.gopluslabs.io

# Optional. Used for full token balances and indexed wallet inventory.
# Mantle Data API is disabled by default because current Moralis Data API chain coverage
# does not expose Mantle wallet/token data. Turn this on only for a supported chain.
MORALIS_API_KEY=
MORALIS_DATA_API_ENABLED=false
MORALIS_BALANCES_ENABLED=false
MORALIS_HISTORY_ENABLED=false
MORALIS_CHAIN=mantle
MORALIS_BASE_URL=https://deep-index.moralis.io/api/v2.2

# Optional. Used for indexed approval logs and token transfer history.
ETHERSCAN_V2_API_KEY=
# MANTLESCAN_API_KEY can be used instead of ETHERSCAN_V2_API_KEY.

# Optional. Used only for real on-chain assessment record commits.
# Without these values /api/assessment/commit returns pending_unavailable and no mock tx hash.
ASSESSMENT_CONTRACT_ADDRESS=
# ASSESSMENT_LOGGER_ADDRESS can be used instead of ASSESSMENT_CONTRACT_ADDRESS.
ASSESSMENT_LOGGER_ADDRESS=
PRIVATE_KEY=
# WALLET_PRIVATE_KEY can be used instead of PRIVATE_KEY.
MANTLE_EXPLORER_BASE_URL=https://mantlescan.xyz
# CHAIN_ID can be used instead of MANTLE_CHAIN_ID.

# Live provider stability budget.
LIVE_REQUEST_TIMEOUT_SEC=3
LIVE_REQUEST_RETRIES=1
LIVE_SCAN_DEADLINE_SEC=15

# Durable local state for trend history and alerts.
# Set MANTLELENS_DISABLE_PERSISTENCE=true to force in-memory demo state.
MANTLELENS_STATE_DB=data/mantlelens.sqlite3
MANTLELENS_DISABLE_PERSISTENCE=false

# Optional. Real transaction simulation provider. Tenderly Node RPC supports
# tenderly_simulateTransaction on a full gateway URL. The app never broadcasts.
TX_SIMULATION_PROVIDER=tenderly_rpc
TX_SIMULATION_RPC_URL=
# TENDERLY_SIMULATION_RPC_URL can be used instead of TX_SIMULATION_RPC_URL.
TX_SIMULATION_RPC_METHOD=tenderly_simulateTransaction
TX_SIMULATION_TIMEOUT_SEC=5

# Optional fallback when no Moralis key is configured.
# JSON array: [{"symbol":"USDT","tokenAddress":"0x...","decimals":6,"priceUsd":1}]
MANTLE_KNOWN_TOKENS_JSON=

# P2.7 wallet-confirmed live demo wallet setup.
# Use the standalone helper at /p2_7_live_wallet_setup.html to deploy a Mantle
# Sepolia demo token and copy the public token address into this allowlist.
# For wallet-popup AssessmentLogger recording, keep backend signer variables empty
# and use ASSESSMENT_CONTRACT_ADDRESS plus browser wallet confirmation.
# MANTLE_CHAIN_ID=5003
# MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
# MANTLE_EXPLORER_BASE_URL=https://sepolia.mantlescan.xyz
# MANTLE_KNOWN_TOKENS_JSON='[{"symbol":"MLDT","tokenAddress":"0xDEPLOYED_TOKEN","decimals":18,"priceUsd":1}]'
